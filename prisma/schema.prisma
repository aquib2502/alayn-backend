datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  BUSINESS_OWNER
  MANAGER
  STAFF
  KITCHEN
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum ShiftAssignmentStatus {
  ASSIGNED
  ABSENT
  PRESENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum LeaveStatus {
  REQUESTED
  APPROVED
  REJECTED
}

enum SwapStatus {
  REQUESTED
  APPROVED
  REJECTED
}

enum StockReason {
  SALE
  WASTE
  PURCHASE
  ADJUSTMENT
}

enum POStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
}

enum AlertType {
  LOW_STOCK
  EXPIRY
}

enum AlertStatus {
  OPEN
  RESOLVED
}

enum OrderSource {
  COUNTER
  QR
  DELIVERY
}

enum OrderStatus {
  RECEIVED
  PREPARING
  READY
  SERVED
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  UPI
  CARD
  CASH
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum WasteReasonType {
  SPOILAGE
  OVER_PREP
  RETURN
  ERROR
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  businessId   String?       @db.Uuid
  email        String        @unique
  passwordHash String
  name         String
  role         Role
  phoneNo      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  
  business     Business?     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessOwner BusinessOwner?
  outlets      UserOutlet[]
  refreshTokens RefreshToken[]
  employees    Employee[]
}

model Business {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  locationsCount String?
  businessType   String?
  contactDetail  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  // Relations
  outlets      Outlet[]
  users        User[]
  owners       BusinessOwner[]
  subscription Subscription?
}

model BusinessOwner {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @unique @db.Uuid
  businessId String    @db.Uuid
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INACTIVE
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  businessId           String             @unique @db.Uuid
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(ACTIVE)
  planId               String             @default("BASIC")
  trialStart           DateTime?
  trialEnd             DateTime?
  currentPeriodStart   DateTime           @default(now())
  currentPeriodEnd     DateTime
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  business             Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Outlet {
  id               String        @id @default(uuid()) @db.Uuid
  businessId       String        @db.Uuid
  name             String
  address          String
  city             String
  state            String
  country          String
  cgstRateDecimal  Decimal       @default(9.0) @db.Decimal(5, 2)
  sgstRateDecimal  Decimal       @default(9.0) @db.Decimal(5, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  business         Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  users            UserOutlet[]
  employees        Employee[]
  shifts           Shift[]
  shiftAssignments ShiftAssignment[]
  attendance       Attendance[]
  leaveRequests    LeaveRequest[]
  shiftSwapRequests ShiftSwapRequest[]
  items            Item[]
  stockBatches     StockBatch[]
  stockLedgerEntries StockLedgerEntry[]
  suppliers        Supplier[]
  purchaseOrders   PurchaseOrder[]
  stockAlerts      StockAlert[]
  menuCategories   MenuCategory[]
  menuItems        MenuItem[]
  tableTokens      TableToken[]
  orders           Order[]
  wasteLogs        WasteLog[]
  dailySalesSummaries DailySalesSummary[]
  feedbacks        Feedback[]
  staffQueries     StaffQuery[]
  tickets          Ticket[]
}

model UserOutlet {
  userId     String   @db.Uuid
  outletId   String   @db.Uuid
  assignedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@id([userId, outletId])
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  tokenHash  String   @unique
  userId     String   @db.Uuid
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Employee {
  id          String         @id @default(uuid()) @db.Uuid
  outletId    String         @db.Uuid
  userId      String?        @db.Uuid
  email       String?
  name        String
  phone       String
  role        Role
  joiningDate DateTime
  status      EmployeeStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  outlet            Outlet             @relation(fields: [outletId], references: [id], onDelete: Cascade)
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  documents         EmployeeDocument[]
  shiftAssignments  ShiftAssignment[]
  attendance        Attendance[]
  leaveRequests     LeaveRequest[]
  swapFromRequests  ShiftSwapRequest[] @relation("SwapFrom")
  swapToRequests    ShiftSwapRequest[] @relation("SwapTo")
  performanceNotes  PerformanceNote[]  @relation("PerformanceEmployee")
  writtenNotes      PerformanceNote[]  @relation("PerformanceWriter")
  staffQueries      StaffQuery[]

  @@index([outletId])
}

model EmployeeDocument {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @db.Uuid
  name       String
  fileUrl    String
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Shift {
  id        String    @id @default(uuid()) @db.Uuid
  outletId  String    @db.Uuid
  name      String
  startTime String    // Format: "HH:MM"
  endTime   String    // Format: "HH:MM"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  outlet      Outlet            @relation(fields: [outletId], references: [id], onDelete: Cascade)
  assignments ShiftAssignment[]
  swapRequests ShiftSwapRequest[]

  @@index([outletId])
}

model ShiftAssignment {
  id         String                @id @default(uuid()) @db.Uuid
  employeeId String                @db.Uuid
  shiftId    String                @db.Uuid
  date       DateTime              @db.Date
  status     ShiftAssignmentStatus @default(ASSIGNED)
  outletId   String                @db.Uuid
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  outlet   Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([employeeId, shiftId, date])
  @@index([outletId])
}

model Attendance {
  id           String           @id @default(uuid()) @db.Uuid
  employeeId   String           @db.Uuid
  date         DateTime         @db.Date
  checkInTime  DateTime
  checkOutTime DateTime?
  status       AttendanceStatus @default(PRESENT)
  outletId     String           @db.Uuid
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  outlet   Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
}

model LeaveRequest {
  id            String      @id @default(uuid()) @db.Uuid
  employeeId    String      @db.Uuid
  startDate     DateTime    @db.Date
  endDate       DateTime    @db.Date
  reason        String
  status        LeaveStatus @default(REQUESTED)
  approvedById  String?     @db.Uuid // Manager or Owner User ID
  outletId      String      @db.Uuid
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  outlet   Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
}

model ShiftSwapRequest {
  id             String     @id @default(uuid()) @db.Uuid
  fromEmployeeId String     @db.Uuid
  toEmployeeId   String     @db.Uuid
  shiftId        String     @db.Uuid
  date           DateTime   @db.Date
  status         SwapStatus @default(REQUESTED)
  outletId       String     @db.Uuid
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  fromEmployee Employee @relation("SwapFrom", fields: [fromEmployeeId], references: [id], onDelete: Cascade)
  toEmployee   Employee @relation("SwapTo", fields: [toEmployeeId], references: [id], onDelete: Cascade)
  shift        Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  outlet       Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
}

model PerformanceNote {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @db.Uuid
  writerId   String   @db.Uuid // Employee ID of the supervisor writing it
  note       String
  rating     Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation("PerformanceEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  writer   Employee @relation("PerformanceWriter", fields: [writerId], references: [id], onDelete: Cascade)
}

model Item {
  id               String    @id @default(uuid()) @db.Uuid
  name             String
  sku              String
  category         String
  unit             String
  reorderThreshold Decimal   @db.Decimal(12, 4)
  unitCostPaise    Int
  outletId         String    @db.Uuid
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  outlet             Outlet              @relation(fields: [outletId], references: [id], onDelete: Cascade)
  batches            StockBatch[]
  ledgerEntries      StockLedgerEntry[]
  recipes            Recipe[]
  purchaseOrderItems PurchaseOrderItem[]
  alerts             StockAlert[]

  @@unique([outletId, sku])
  @@index([outletId])
}

model StockBatch {
  id            String    @id @default(uuid()) @db.Uuid
  itemId        String    @db.Uuid
  quantity      Decimal   @db.Decimal(12, 4)
  expiryDate    DateTime
  batchNumber   String
  unitCostPaise Int
  outletId      String    @db.Uuid
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
}

model StockLedgerEntry {
  id          String      @id @default(uuid()) @db.Uuid
  itemId      String      @db.Uuid
  change      Decimal     @db.Decimal(12, 4)
  reason      StockReason
  referenceId String?     // e.g. PO ID, Order ID, WasteLog ID
  outletId    String      @db.Uuid
  createdAt   DateTime    @default(now())

  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
}

model Recipe {
  menuItemId      String  @db.Uuid
  itemId          String  @db.Uuid
  quantityPerUnit Decimal @db.Decimal(12, 4)

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([menuItemId, itemId])
}

model Supplier {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  contactPerson String
  phone         String
  email         String
  address       String
  outletId      String    @db.Uuid
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  outlet         Outlet          @relation(fields: [outletId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([outletId])
}

model PurchaseOrder {
  id               String          @id @default(uuid()) @db.Uuid
  supplierId       String          @db.Uuid
  status           POStatus        @default(DRAFT)
  totalAmountPaise Int
  outletId         String          @db.Uuid
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?

  supplier Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade) // Note: references Outlet for authorization scopes
  actualSupplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items    PurchaseOrderItem[]

  @@index([outletId])
}

model PurchaseOrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  purchaseOrderId String   @db.Uuid
  itemId          String   @db.Uuid
  orderedQuantity Decimal  @db.Decimal(12, 4)
  receivedQuantity Decimal @default(0) @db.Decimal(12, 4)
  unitCostPaise   Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item          Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model StockAlert {
  id        String      @id @default(uuid()) @db.Uuid
  itemId    String      @db.Uuid
  type      AlertType
  message   String
  status    AlertStatus @default(OPEN)
  outletId  String      @db.Uuid
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
}

model MenuCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String
  imageUrl    String?
  isActive    Boolean   @default(true)
  outletId    String    @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  outlet    Outlet     @relation(fields: [outletId], references: [id], onDelete: Cascade)
  menuItems MenuItem[]

  @@index([outletId])
}

model MenuItem {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String
  imageUrl    String?
  pricePaise  Int
  categoryId  String    @db.Uuid
  isVeg       Boolean   @default(true)
  isActive    Boolean   @default(true)
  outletId    String    @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  outlet     Outlet       @relation(fields: [outletId], references: [id], onDelete: Cascade)
  recipes    Recipe[]
  orderItems OrderItem[]

  @@index([outletId])
}

model TableToken {
  id          String   @id @default(uuid()) @db.Uuid
  tableNumber Int
  token       String   @unique
  expiresAt   DateTime
  outletId    String   @db.Uuid
  createdAt   DateTime @default(now())

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
}

model Order {
  id            String      @id @default(uuid()) @db.Uuid
  tableNumber   Int?
  source        OrderSource
  status        OrderStatus @default(RECEIVED)
  subtotalPaise Int
  cgstPaise     Int
  sgstPaise     Int
  taxPaise      Int
  totalPaise    Int
  outletId      String      @db.Uuid
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  outlet         Outlet              @relation(fields: [outletId], references: [id], onDelete: Cascade)
  items          OrderItem[]
  statusHistory  OrderStatusHistory[]
  payments       Payment[]
  feedbacks      Feedback[]

  @@index([outletId])
}

model OrderItem {
  id             String   @id @default(uuid()) @db.Uuid
  orderId        String   @db.Uuid
  menuItemId     String   @db.Uuid
  quantity       Int
  unitPricePaise Int
  subtotalPaise  Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

model OrderStatusHistory {
  id          String      @id @default(uuid()) @db.Uuid
  orderId     String      @db.Uuid
  status      OrderStatus
  changedById String?     @db.Uuid // User ID of the employee
  comment     String?
  createdAt   DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String        @id @default(uuid()) @db.Uuid
  orderId     String        @db.Uuid
  amountPaise Int
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model WasteReason {
  id          String          @id @default(uuid()) @db.Uuid
  reason      WasteReasonType
  description String
  createdAt   DateTime        @default(now())
}

model WasteLog {
  id                 String          @id @default(uuid()) @db.Uuid
  itemId             String          @db.Uuid
  quantity           Decimal         @db.Decimal(12, 4)
  costAtLoggingPaise Int
  reason             WasteReasonType
  loggedById         String          @db.Uuid // User ID
  outletId           String          @db.Uuid
  createdAt          DateTime        @default(now())

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
}

model DailySalesSummary {
  id                String   @id @default(uuid()) @db.Uuid
  date              DateTime @db.Date
  grossSalesPaise   Int
  cogsPaise         Int
  grossProfitPaise  Int
  orderCount        Int
  itemBreakdownJson String   // JSON details: { [menuItemId]: quantity }
  outletId          String   @db.Uuid
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([outletId, date])
  @@index([outletId])
}

model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  outletId  String   @db.Uuid
  orderId   String   @db.Uuid
  rating    Int
  comment   String
  source    String   // e.g. "RECEIPT", "QR"
  createdAt DateTime @default(now())

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([outletId])
}

model StaffQuery {
  id          String   @id @default(uuid()) @db.Uuid
  employeeId  String   @db.Uuid
  category    String
  description String
  status      String   @default("OPEN")
  outletId    String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  outlet   Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
}

model Ticket {
  id          String         @id @default(uuid()) @db.Uuid
  title       String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(NORMAL)
  sourceTable String         // "Feedback" or "StaffQuery"
  sourceId    String         @db.Uuid
  outletId    String         @db.Uuid
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  outlet    Outlet          @relation(fields: [outletId], references: [id], onDelete: Cascade)
  histories TicketHistory[]

  @@index([outletId])
}

model TicketHistory {
  id          String       @id @default(uuid()) @db.Uuid
  ticketId    String       @db.Uuid
  status      TicketStatus
  changedById String?      @db.Uuid // User ID of assignee/resolver
  comment     String?
  createdAt   DateTime     @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}
